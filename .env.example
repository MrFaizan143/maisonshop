# Supabase configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/<project>/settings/api

# Project URL
SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon / publishable key (safe to expose in client-side code)
SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>

# Project reference ID
VITE_SUPABASE_PROJECT_ID=<project-ref>

# Service role key (server-side only — never expose to the client)
# Used by the SSR admin client (src/integrations/supabase/client.server.ts)
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
